Options -Indexes

# ── Roteamento A/B ──────────────────────────────
# /    → V2 (nova seção de oferta)
# /v1  → V1 (seção de oferta original)
# /v2  → V2
RewriteEngine On
RewriteRule ^$ v2/index.html [L]
RewriteRule ^v1/?$ v1/index.html [L]
RewriteRule ^v2/?$ v2/index.html [L]
# Assets pedidos a partir de /v1/... ou /v2/... caem na pasta compartilhada
RewriteRule ^v[12]/(assets/.*)$ $1 [L]

# Correct MIME types for fonts and media
AddType font/woff2 .woff2
AddType font/woff .woff
AddType font/ttf .ttf
AddType font/eot .eot
AddType image/webp .webp
AddType image/svg+xml .svg
AddType application/javascript .js
AddType text/css .css

# CORS for fonts (needed by some browsers)
<FilesMatch "\.(woff|woff2|ttf|eot|svg)$">
    Header set Access-Control-Allow-Origin "*"
</FilesMatch>

# Cache headers
<FilesMatch "\.(css|js|woff|woff2|ttf|eot|webp|jpg|jpeg|png|gif|svg|ico)$">
    Header set Cache-Control "max-age=86400, public"
</FilesMatch>
